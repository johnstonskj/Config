    zsh-zoxide-plugin
    zsh-zplugins-plugin
)

SKIP_PLUGINS=(
    zsh-antigravity-plugin
)

for plugin in "${ALL_PLUGINS[@]}"; do
    if (( SKIP_PLUGINS[(Ie)$plugin] )); then
        echo "Skipping plugin ${plugin}"
    else
        echo "Processing plugin ${plugin}..."
        pushd ${plugin} >/dev/null 2>&1
        git_workflow ${plugin}
        popd >/dev/null 2>&1
    fi
done